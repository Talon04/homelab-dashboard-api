# =============================================================================
# Homelab Dashboard API - Environment Variables
# =============================================================================
# Copy this file to .env and adjust the values for your environment.
# The .env file is loaded automatically on startup (python-dotenv).
#
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Data directory
# Override the default persistent data directory path.
# Defaults to <project_root>/data when not set.
# -----------------------------------------------------------------------------
# DATA_DIR=/app/data

# -----------------------------------------------------------------------------
# Testing / Development
# Set to "1" to use mock containers instead of a live Docker socket.
# Do NOT set this in production.
# -----------------------------------------------------------------------------
# TESTING_MODE=1
